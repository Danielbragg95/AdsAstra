# LLM — absent = mock mode (offline, deterministic). Present = live Claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Force mock on/off regardless of key: 1 = mock, 0 = live
# SIGNALWORK_MOCK=1

# Trend sources
YOUTUBE_API_KEY=

# Storage
# SIGNALWORK_DB=/absolute/path/to/signalwork.db

# Publishing — absent = mock mode. Point at your Postiz instance to go live.
POSTIZ_URL=
POSTIZ_API_KEY=

# Rendered images directory (default: data/assets)
# SIGNALWORK_ASSETS=

# Voiceover — absent = mock provider (playable placeholder WAVs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
